{
  "version": 2,
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "memory": 300,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ],
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "*/10 * * * *"
    }
  ]
}
